{{#if showArc}}
<h2>Your Arc</h2>
<p class="arc-sub">Commit trend across all periods.</p>
<div class="arc-chart">
  {{#each history}}
  <div class="arc-bar" style="height:{{barHeight}}%" title="{{period.label}}: {{signals.totalCommits}} commits">
    <span class="arc-label">{{signals.totalCommits}}</span>
  </div>
  {{/each}}
</div>
{{/if}}
