<!DOCTYPE html>
<html lang="{{language}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <meta name="description" content="{{description}}">
  <meta property="og:title" content="{{title}}">
  <meta property="og:description" content="{{description}}">
  <meta property="og:image" content="{{ogImage}}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;900&display=swap" rel="stylesheet">
  <style>{{{styles}}}</style>
</head>
<body>
<div class="container">
  <div class="hero">
    {{#if llm}}<div class="hero-headline">{{llm.headline}}</div>{{/if}}
    <h1>{{dateRange}}</h1>
    <p class="hero-sub">{{subtitle}}</p>
    {{#if llm}}<p class="hero-archetype">{{llm.archetype}}</p>{{/if}}
  </div>
